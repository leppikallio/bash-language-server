#!/usr/bin/env bash
# Claude Code PostToolUse hook: after a file edit/write, format and verify shell scripts.
# This hook never executes the edited shell script. It only runs formatters and static/syntax checks.
set -u

input=$(cat)

if ! command -v node >/dev/null 2>&1; then
  # Node is already required for bash-language-server, but avoid noisy hook failures.
  exit 0
fi

read -r file cwd <<EOF
$(printf '%s' "$input" | node -e '
const fs = require("fs");
let j = {};
try { j = JSON.parse(fs.readFileSync(0, "utf8")); } catch { process.exit(0); }
const file = j?.tool_input?.file_path || j?.tool_response?.filePath || "";
const cwd = j?.cwd || process.cwd();
console.log(file);
console.log(cwd);
')
EOF

[ -n "${file:-}" ] || exit 0

case "$file" in
  /*) ;;
  *) file="${cwd%/}/$file" ;;
esac

[ -f "$file" ] || exit 0

script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd -P)

format_flag="--format"
if [ "${BASH_AGENT_SHFMT_ON_HOOK:-1}" = "0" ]; then
  format_flag=""
fi

if [ -n "$format_flag" ]; then
  exec "$script_dir/bash-agent-verify" --hook "$format_flag" "$file"
else
  exec "$script_dir/bash-agent-verify" --hook "$file"
fi
